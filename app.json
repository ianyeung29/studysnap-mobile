{
  "expo": {
    "name": "StudySnap",
    "slug": "studysnap",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0a0a0f",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0f"
    },
    "scheme": "studysnap",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.asmrforall1999.studysnap",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "StudySnap needs your microphone to record lectures so you can generate study materials.",
        "NSCameraUsageDescription": "StudySnap needs your camera to photograph whiteboards and handwritten notes.",
        "NSPhotoLibraryUsageDescription": "StudySnap needs photo library access to select images of your notes."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#0a0a0f"
      },
      "package": "com.asmrforall1999.studysnap",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "StudySnap needs your camera to photograph whiteboards and handwritten notes."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "StudySnap needs photo library access to select images of your notes."
        }
      ],
      "expo-audio",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5e87b04c-b02c-4ad0-9246-47b133781d71"
      }
    },
    "owner": "ianyeung30s-team"
  }
}
